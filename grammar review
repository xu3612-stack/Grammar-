<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>JLPT N4 Grammar Trainer</title>

<style>
body {
    font-family: -apple-system, BlinkMacSystemFont;
    background: #f5f5f5;
    padding: 15px;
}

.card {
    background: white;
    padding: 20px;
    margin-bottom: 20px;
    border-radius: 12px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
}

.grammar {
    font-size: 28px;
    font-weight: bold;
    color: #222;
}

.section {
    margin-top: 10px;
}

button {
    margin-top: 10px;
    padding: 10px;
    border: none;
    border-radius: 8px;
    background: #007AFF;
    color: white;
    font-size: 16px;
}

.output {
    margin-top: 10px;
    display: none;
    color: #333;
}
</style>

</head>

<body>

<h2>JLPT N4 Grammar Trainer</h2>

<!-- Card Template -->

<div class="card">
<div class="grammar">〜てしまう</div>

<div class="section"><b>Meaning:</b> 完成 / 遗憾</div>
<div class="section"><b>Structure:</b> Vて + しまう</div>

<div class="section">
<b>Examples:</b><br>
宿題を忘れてしまいました<br>
ケーキを全部食べてしまった<br>
電車で寝てしまいました
</div>

<button onclick="playAudio('teShimau')">▶ 播放音频</button>

<button onclick="toggleOutput(this)">👉 我来造句</button>
<div class="output">
请造句：<br>
1️⃣ 完成含义<br>
2️⃣ 遗憾含义
</div>
</div>

<div class="card">
<div class="grammar">〜てみる</div>

<div class="section"><b>Meaning:</b> 尝试做</div>
<div class="section"><b>Structure:</b> Vて + みる</div>

<div class="section">
<b>Examples:</b><br>
日本料理を食べてみます<br>
この服を着てみました<br>
やってみてください
</div>

<button onclick="playAudio('temiru')">▶ 播放音频</button>

<button onclick="toggleOutput(this)">👉 我来造句</button>
<div class="output">
请造句：<br>
1️⃣ 吃/用东西<br>
2️⃣ 学习相关
</div>
</div>

<div class="card">
<div class="grammar">〜ている</div>

<div class="section"><b>Meaning:</b> 正在 / 状态</div>
<div class="section"><b>Structure:</b> Vて + いる</div>

<div class="section">
<b>Examples:</b><br>
本を読んでいます<br>
結婚しています<br>
雨が降っています
</div>

<button onclick="playAudio('teiru')">▶ 播放音频</button>

<button onclick="toggleOutput(this)">👉 我来造句</button>
<div class="output">
请造句：<br>
1️⃣ 动作进行<br>
2️⃣ 状态
</div>
</div>

<script>
function playAudio(type) {
    let text = "";

    if(type === 'teShimau'){
        text = "てしまう。完成或者遗憾。宿題を忘れてしまいました。ケーキを食べてしまった。電車で寝てしまいました。";
    }

    if(type === 'temiru'){
        text = "てみる。尝试做某事。日本料理を食べてみます。この服を着てみました。やってみてください。";
    }

    if(type === 'teiru'){
        text = "ている。正在进行或者状态。本を読んでいます。結婚しています。雨が降っています。";
    }

    let speech = new SpeechSynthesisUtterance(text);
    speech.lang = "ja-JP";
    speech.rate = 0.9;
    speechSynthesis.speak(speech);
}

function toggleOutput(btn){
    let output = btn.nextElementSibling;
    output.style.display = output.style.display === "block" ? "none" : "block";
}
</script>

</body>
</html>
